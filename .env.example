# =============================================================================
# Pathoryx — Environment Template
# Copy this file to .env and fill in all CHANGE_ME values.
# NEVER commit .env to source control.
# =============================================================================

# --- Database --------------------------------------------------------------- #
# PostgreSQL connection string. Database must be created manually (see WINDOWS_SETUP.md).
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://pathoryx_user:CHANGE_ME@localhost:5432/pathoryx

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_ECHO_SQL=false

# --- Service Identity ------------------------------------------------------- #
PATHORYX_ENVIRONMENT=development
PATHORYX_SITE_CODE=site_local
PATHORYX_SERVICE_VERSION=1.0.0

# --- Config Paths ----------------------------------------------------------- #
BABELSHARK_CONFIG_PATH=./configs/babelshark_config.yaml
QC_CONFIG_PATH=./configs/qc_config.yaml
QC_SERVICE_CONFIG=./configs/qc_service.yaml
DICOM_CONFIG_PATH=./configs/dicom_config.yaml
RECOVERY_SENTRY_CONFIG=./configs/recovery_sentry.yaml

# --- Dashboard -------------------------------------------------------------- #
PATHORYX_DASHBOARD_HOST=127.0.0.1
PATHORYX_DASHBOARD_PORT=8090

# --- PASNET (optional — set enabled: true in babelshark_config.yaml first) -- #
PASNET_SERVER=CHANGE_ME
PASNET_USERNAME=CHANGE_ME
PASNET_PASSWORD=CHANGE_ME

# --- LIS (optional — set lis.enabled: true in dicom_config.yaml first) ------ #
LIS_SQL_SERVER=CHANGE_ME
LIS_SQL_USERNAME=CHANGE_ME
LIS_SQL_PASSWORD=CHANGE_ME

# --- Nexus artifact registry (optional) ------------------------------------- #
NEXUS_USERNAME=CHANGE_ME
NEXUS_PASSWORD=CHANGE_ME

# --- Observability ---------------------------------------------------------- #
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pathoryx
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_PORT=9090
PROMETHEUS_METRICS_ENABLED=true

# --- Health Check ----------------------------------------------------------- #
HEALTH_HTTP_PORT=8080
HEALTH_HTTP_ENABLED=true

# --- RecoverySentry --------------------------------------------------------- #
# Backward-compat: comma-separated watch folders (used when RECOVERY_SENTRY_CONFIG is absent)
FAILED_WATCHER_FOLDERS=C:/Users/Public/projects/Pathoryx/data/failed,C:/Users/Public/projects/Pathoryx/data/suspicious
