# =============================================================================
# Palantir — Windows Environment Template
# Copy this file to .env and fill in all CHANGE_ME values.
# NEVER commit .env to source control.
#
# This template uses Windows paths under C:\Users\Public\projects\Palantir\.
# All config path values use forward slashes — Python and YAML handle them
# correctly on Windows. Backslashes also work but require escaping.
# =============================================================================

# --- Database --------------------------------------------------------------- #
# PostgreSQL connection string. Create the database first (see WINDOWS_SETUP.md).
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg2://pathoryx_user:CHANGE_ME@localhost:5432/pathoryx

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_ECHO_SQL=false

# --- Service Identity ------------------------------------------------------- #
PATHORYX_ENVIRONMENT=development
PATHORYX_SITE_CODE=site_windows
PATHORYX_SERVICE_VERSION=1.0.0

# --- Config Paths (Windows) ------------------------------------------------- #
# Use the Windows-specific config variants for correct data paths.
BABELSHARK_CONFIG_PATH=C:/Users/Public/projects/Palantir/configs/babelshark_config.windows.yaml
QC_CONFIG_PATH=C:/Users/Public/projects/Palantir/configs/qc_config.windows.yaml
QC_SERVICE_CONFIG=C:/Users/Public/projects/Palantir/configs/qc_service.yaml
DICOM_CONFIG_PATH=C:/Users/Public/projects/Palantir/configs/dicom_config.windows.yaml
RECOVERY_SENTRY_CONFIG=C:/Users/Public/projects/Palantir/configs/recovery_sentry.windows.yaml
SCANNER_FLEET_CONFIG=C:/Users/Public/projects/Palantir/configs/scanner_fleet.yaml

# --- Input Root Allowlist --------------------------------------------------- #
# Comma-separated list of directory roots that the pipeline is allowed to
# read input files from. Prevents path traversal outside approved locations.
PALANTIR_ALLOWED_INPUT_ROOTS=C:/Users/Public/projects/Palantir/data

# --- Dashboard -------------------------------------------------------------- #
PATHORYX_DASHBOARD_HOST=127.0.0.1
PATHORYX_DASHBOARD_PORT=8090

# --- PASNET (optional — set enabled: true in babelshark_config.windows.yaml first) #
PASNET_SERVER=CHANGE_ME
PASNET_USERNAME=CHANGE_ME
PASNET_PASSWORD=CHANGE_ME

# --- Sectra PACS Upload (upload_service) --------------------------------------- #
#
# SECTRA_DRY_RUN=true (default) — C-STORE commands are built and logged but
# NOT transmitted.  Upload is marked completed with method="storescu_dry_run".
# Safe for development and staging.
#
# To enable real PACS transmission:
#   1. Verify connectivity: ping path-pacs2
#      Test-NetConnection path-pacs2 -Port 32001    (PowerShell)
#   2. Set SECTRA_DRY_RUN=false
#   3. Set SECTRA_HOST, SECTRA_REMOTE_AE, SECTRA_LOCAL_AE
#
SECTRA_DRY_RUN=true
SECTRA_HOST=path-pacs2
SECTRA_PORT=32001
SECTRA_REMOTE_AE=DICOM_STORAGE
SECTRA_LOCAL_AE=DICOM_STORAGE
#
# Full path to storescu.exe from the DCMTK installation.
# If DCMTK bin dir is already on PATH you can use just: SECTRA_CSTORE_BIN=storescu
SECTRA_CSTORE_BIN=C:/Program Files/dcmtk-3.7.0-win64-dynamic/bin/storescu.exe
#
# Advanced tuning (defaults are production-safe):
# SECTRA_CSTORE_BATCH_SIZE=500       max .dcm files per storescu call
# SECTRA_UPLOAD_TIMEOUT_SECONDS=1800 per-batch C-STORE timeout
#
# Uploader loop tuning:
# UPLOADER_TRIGGER_POLL_INTERVAL=10  seconds between trigger polls
# UPLOADER_MAX_RETRIES=3             per-trigger retry attempts
# UPLOADER_CIRCUIT_BREAK_THRESHOLD=5 consecutive failures before circuit opens
# UPLOADER_CIRCUIT_RESET_SECONDS=60  pause before circuit half-opens

# --- LIS (optional — set lis.enabled: true in dicom_config.windows.yaml first) ---- #
LIS_SQL_SERVER=CHANGE_ME
LIS_SQL_USERNAME=CHANGE_ME
LIS_SQL_PASSWORD=CHANGE_ME

# --- Nexus artifact registry (optional) ------------------------------------- #
NEXUS_USERNAME=CHANGE_ME
NEXUS_PASSWORD=CHANGE_ME

# --- Observability ---------------------------------------------------------- #
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pathoryx
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_PORT=9090
PROMETHEUS_METRICS_ENABLED=true

# --- Health Check ----------------------------------------------------------- #
HEALTH_HTTP_PORT=8080
HEALTH_HTTP_ENABLED=true

# --- RecoverySentry --------------------------------------------------------- #
# Backward-compat: comma-separated watch folders (used when RECOVERY_SENTRY_CONFIG is absent)
FAILED_WATCHER_FOLDERS=C:/Users/Public/projects/Palantir/data/failed,C:/Users/Public/projects/Palantir/data/suspicious
