/*
 * Nextflow configuration for Pathoryx.
 */

manifest {
    name            = 'pathoryx'
    version         = '1.0.0'
    description     = 'Whole-slide image ingestion and processing pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10'
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------

profiles {

    local {
        executor.name    = 'local'
        executor.cpus    = 8
        executor.memory  = '32 GB'
        process.executor = 'local'
        docker.enabled   = false
    }

    docker {
        docker.enabled      = true
        docker.runOptions   = '--rm --env-file ../.env'
        process.executor    = 'local'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.executor       = 'local'
    }

    slurm {
        executor.name           = 'slurm'
        executor.queueSize      = 100
        executor.submitRateLimit = '10/1min'
        process.executor        = 'slurm'
        process.queue           = 'compute'
        process.clusterOptions  = '--account=pathoryx'
        singularity.enabled     = true
        singularity.autoMounts  = true
    }

    kubernetes {
        executor.name          = 'k8s'
        k8s.namespace          = 'pathoryx'
        k8s.storageClaimName   = 'pathoryx-pvc'
        k8s.storageMountPath   = '/data'
        process.executor       = 'k8s'
    }

    // Lightweight profile for CI and integration tests
    test {
        executor.name    = 'local'
        executor.cpus    = 2
        executor.memory  = '8 GB'
        process.executor = 'local'
        docker.enabled   = false
        params.input_manifest = "test-data/test_manifest.csv"
        params.outdir         = "test-results"

        process {
            withLabel: 'intake' { time = '5 min' }
            withLabel: 'qc'     { time = '10 min'; cpus = 1; memory = '4 GB' }
            withLabel: 'dicom'  { time = '10 min' }
            withLabel: 'upload' { time = '5 min' }
        }
    }

}

// ---------------------------------------------------------------------------
// Default process resource requirements and retry logic
// ---------------------------------------------------------------------------

process {
    // Global defaults
    errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
    maxRetries    = 3

    withLabel: 'intake' {
        cpus          = 2
        memory        = '4 GB'
        time          = '30 min'
        maxRetries    = 3
        errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
        // Exponential backoff: 30s, 60s, 90s
    }

    withLabel: 'qc' {
        cpus          = 4
        memory        = '16 GB'
        time          = '60 min'
        maxRetries    = 2
        errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
        // Uncomment for GPU nodes:
        // accelerator = [request: 1, type: 'nvidia-tesla-v100']
        // clusterOptions = '--gres=gpu:1'  // SLURM GPU request
    }

    withLabel: 'dicom' {
        cpus          = 4
        memory        = '32 GB'
        time          = '4 h'
        maxRetries    = 3
        errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
    }

    withLabel: 'upload' {
        cpus          = 1
        memory        = '2 GB'
        time          = '60 min'
        maxRetries    = 5
        errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
    }
}

// ---------------------------------------------------------------------------
// Environment variable passthrough
// ---------------------------------------------------------------------------

env {
    DATABASE_URL                  = System.env.DATABASE_URL ?: ''
    BABELSHARK_CONFIG             = System.env.BABELSHARK_CONFIG ?: ''
    QC_SERVICE_CONFIG             = System.env.QC_SERVICE_CONFIG ?: ''
    DICOM_CONFIG                  = System.env.DICOM_CONFIG ?: ''
    SECTRA_HOST                   = System.env.SECTRA_HOST ?: ''
    SECTRA_PORT                   = System.env.SECTRA_PORT ?: '4242'
    SECTRA_REMOTE_AE              = System.env.SECTRA_REMOTE_AE ?: ''
    SECTRA_LOCAL_AE               = System.env.SECTRA_LOCAL_AE ?: ''
    PATHORYX_ALLOWED_INPUT_ROOTS  = System.env.PATHORYX_ALLOWED_INPUT_ROOTS ?: ''
    LOG_LEVEL                     = System.env.LOG_LEVEL ?: 'INFO'
    ENVIRONMENT                   = System.env.ENVIRONMENT ?: 'production'
}

// ---------------------------------------------------------------------------
// Report + timeline output
// ---------------------------------------------------------------------------

report {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_timeline.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/reports/pipeline_dag.svg"
    overwrite = true
}

// ---------------------------------------------------------------------------
// Resume / work directory
// ---------------------------------------------------------------------------

workDir = '.nextflow_work'
